# ─── Cup Radar — Environment Variables ───────────────────────────────────────
# Copy this file to .env.local and fill in values.
# .env.local is gitignored — never commit real keys.

# ── football-data.org API key ─────────────────────────────────────────────────
# Free tier: https://www.football-data.org/client/register
# Provides live scores, standings, and match data for FIFA World Cup 2026.
# Without this key the dashboard uses local JSON data (still fully functional).
VITE_FOOTBALL_API_KEY=your_key_here

# ── OpenWeatherMap API key ────────────────────────────────────────────────────
# Free tier: https://openweathermap.org/api (One Call API or 5-day forecast)
# Provides matchday weather forecasts for Lumen Field (within 5 days of match).
# Without this key weather cards show a placeholder message.
VITE_WEATHER_API_KEY=your_key_here
